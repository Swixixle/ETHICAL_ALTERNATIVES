# Copy this file to server/.env (EthicalAlt server always loads that path).
# Vite reads env from client/ for VITE_* — see client README notes in root README.

# Server
ANTHROPIC_API_KEY=
# Optional: override defaults
ANTHROPIC_VISION_MODEL=claude-sonnet-4-6
ANTHROPIC_INVESTIGATION_MODEL=claude-sonnet-4-6
ETSY_API_KEY=
PORT=3001
NODE_ENV=development

# CORS — comma-separated origins for production static site + local dev
# CORS_ORIGIN=https://your-static.onrender.com,http://localhost:5173

# Optional PostgreSQL for pre-built incumbent_profiles (see server/db/schema.sql)
# DATABASE_URL=postgresql://user:pass@host:5432/ethic...
# Load schema + Walmart seed:
#   psql "$DATABASE_URL" -f server/db/schema.sql
#   psql "$DATABASE_URL" -f server/db/seed_walmart.sql
#
# Volume 1 profiles (15 companies + altria slug; JSON under server/db/profiles_v1/):
#   cd server && npm run db:import:v1
#
# Volume 2 (15 + Sysco + 5 positive / clean_card; JSON under server/db/profiles_v2/):
#   cd server && npm run db:import:v2

# Client (production build — your deployed API origin, no trailing slash)
# VITE_API_URL=https://ethicalalt-server.onrender.com

# Vite dev proxy target override (optional)
# VITE_DEV_API=http://127.0.0.1:3001

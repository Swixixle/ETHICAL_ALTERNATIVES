# =============================================================================
# Minimum for camera → tap → investigate (Express calls Anthropic)
# =============================================================================
ANTHROPIC_API_KEY=

# =============================================================================
# Optional — provider fallbacks when Claude errors (rare; free tiers can help)
# =============================================================================
# PERPLEXITY_API_KEY=
# GEMINI_API_KEY=
# COURTLISTENER_API_KEY=   # optional — federal docket search in live perimeter check
# PERIMETER_ED25519_PKCS8_DER_B64=   # optional Ed25519 PKCS#8 DER (base64) to sign perimeter payloads

# Optional model overrides (see server/services/aiProvider.js)
# ANTHROPIC_INVESTIGATION_MODEL=claude-sonnet-4-6
# ANTHROPIC_VISION_MODEL=claude-sonnet-4-6

# =============================================================================
# Optional — PostgreSQL (board, profiles in DB, witnesses, workers, etc.)
# Without DATABASE_URL, pool is null: many routes still work; persistence
# features return empty rows or 503. See server/db/pool.js + routes that use pool.
# =============================================================================
# DATABASE_URL=postgresql://user:pass@localhost:5432/ethicalalt

# =============================================================================
# Server
# =============================================================================
# PORT=3001
# CORS_ORIGIN=http://localhost:5173
